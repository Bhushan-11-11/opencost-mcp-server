# Copy to .env and edit values for local runs.

SJH_RESUME_PATH=/Users/nagabhushan.addala/Desktop/AGent/Naga_addala_resume.pdf
SJH_COVER_LETTER_PATH=/Users/nagabhushan.addala/Desktop/AGent/Naga_addala_coverletter.pdf

SJH_JOB_FILE=/absolute/path/to/job_description.txt
SJH_OUTPUT_DIR=/absolute/path/to/output_directory
SJH_APPLICATION_PACKET_PATH=/absolute/path/to/output_directory/application_packet.json
SJH_PDF_OUTPUT_DIR=/absolute/path/to/output_directory/pdf

# Gemini runtime
SJH_GEMINI_API_KEY=your_gemini_api_key
SJH_GEMINI_MODEL=gemini-flash-latest
SJH_GEMINI_TIMEOUT_SECONDS=180
SJH_GEMINI_TEMPERATURE=0.1

# Retrieval stack
SJH_USE_QDRANT=true
SJH_EMBEDDING_MODEL=models/gemini-embedding-001
SJH_QDRANT_STORAGE_PATH=/absolute/path/to/qdrant_storage
SJH_QDRANT_COLLECTION_NAME=resume_claims

# Execution
SJH_LEDGER_PATH=/absolute/path/to/output_directory/submission_ledger.jsonl
SJH_SUBMISSION_PROVIDERS=stackone greenhouse workday
